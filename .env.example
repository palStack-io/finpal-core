# ================================================================
# FinPal - Environment Configuration
# ================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ================================================================
# Database (required)
# ================================================================
DB_USER=finpal
DB_PASSWORD=change_me_strong_password
DB_NAME=finpal

# ================================================================
# Security (required)
# Generate with: openssl rand -hex 32
# ================================================================
SECRET_KEY=change_me_run_openssl_rand_hex_32
JWT_SECRET_KEY=change_me_run_openssl_rand_hex_32

# ================================================================
# Application
# ================================================================
LOG_LEVEL=INFO
DISABLE_SIGNUPS=False

# Port nginx listens on (default: 80)
HTTP_PORT=80

# ================================================================
# Feature Flags
# ================================================================
INVESTMENT_TRACKING_ENABLED=true
SIMPLEFIN_ENABLED=true

# Financial Modeling Prep API key (optional, for investment data)
FMP_API_KEY=

# ================================================================
# Email - for password reset (optional)
# ================================================================
EMAIL_ENABLED=false
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# ================================================================
# OIDC Single Sign-On (optional)
# ================================================================
OIDC_ENABLED=false
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER=
OIDC_DISCOVERY_URL=
OIDC_PROVIDER_NAME=SSO
OIDC_LOGOUT_URI=
APP_URL=http://localhost
LOCAL_LOGIN_DISABLE=False
